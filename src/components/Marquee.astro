---
// src/components/Marquee.astro
const items = [
  "Impression numérique","Conception graphique","Grand format",
  "Tee-shirt personnalisé","Découpe flex adhésif","Kakemono",
  "Flyers & Cartes de visite","Aménagement d'espace"
];
const doubled = [...items, ...items]; // double pour la boucle infinie
---

<div class="marquee-band">
  <div class="marquee-inner" aria-hidden="true">
    {doubled.map(item => (
      <span class="marquee-item">{item}</span>
    ))}
  </div>
</div>

<style>
.marquee-band { background:var(--red);padding:14px 0;overflow:hidden;white-space:nowrap; }
.marquee-inner { display:inline-flex;animation:marquee 20s linear infinite; }
.marquee-item {
  font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;
  letter-spacing:3px;text-transform:uppercase;color:white;
  padding:0 48px;display:inline-flex;align-items:center;gap:16px;
}
.marquee-item::after { content:'★';font-size:10px;opacity:0.7; }
@keyframes marquee {
  0%   { transform:translateX(0); }
  100% { transform:translateX(-50%); }
}
</style>
