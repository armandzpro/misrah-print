---
// src/components/Testimonials.astro
import testimonials from '../content/testimonials.json';
---

<section class="testimonials-section">
  <div class="testimonials-inner">
    <div class="section-tag">Ce qu'ils disent</div>
    <h2 class="section-title reveal">Ils nous font<br><em>confiance</em></h2>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class="testimonial-card reveal" style={`transition-delay:${i * 0.1}s`}>
          <div class="testimonial-quote">"</div>
          <p class="testimonial-text">{t.text}</p>
          <div class="testimonial-footer">
            <div class="testimonial-stars">
              {Array.from({ length: t.rating }).map(() => (
                <span class="star">★</span>
              ))}
            </div>
            <div class="testimonial-author">
              <div class="author-name">{t.name}</div>
              <div class="author-role">{t.role} · {t.company}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.testimonials-section {
  background: #f5f1ed;
  padding: 120px 60px;
}
.testimonials-inner { max-width:1200px;margin:0 auto; }
.testimonials-section .section-tag { color:#b81215; }
.testimonials-section .section-tag::before { background:#b81215; }
.testimonials-section .section-title { color:#1e222e; }
.testimonials-section .section-title em { color:var(--red); }

.testimonials-grid {
  display:grid;grid-template-columns:repeat(3,1fr);gap:24px;
}
.testimonial-card {
  background:white;border-radius:8px;padding:36px 32px;
  position:relative;overflow:hidden;
  box-shadow:0 2px 20px rgba(30,34,46,0.07);
  transition:transform 0.3s,box-shadow 0.3s;
}
.testimonial-card:hover {
  transform:translateY(-6px);
  box-shadow:0 12px 40px rgba(30,34,46,0.13);
}
.testimonial-card::after {
  content:'';position:absolute;bottom:0;left:0;width:0;height:3px;
  background:var(--red);transition:width 0.4s ease;
}
.testimonial-card:hover::after { width:100%; }

.testimonial-quote {
  font-family:'Barlow Condensed',sans-serif;
  font-size:72px;font-weight:900;line-height:0.7;
  color:var(--red);opacity:0.15;margin-bottom:16px;
}
.testimonial-text {
  font-size:15px;color:#444;line-height:1.8;font-weight:400;
  margin-bottom:28px;
}
.testimonial-footer { display:flex;flex-direction:column;gap:10px; }
.testimonial-stars { display:flex;gap:3px; }
.star { color:var(--red);font-size:16px; }
.author-name {
  font-family:'Barlow Condensed',sans-serif;
  font-size:17px;font-weight:700;text-transform:uppercase;
  letter-spacing:0.5px;color:#1e222e;
}
.author-role { font-size:12px;color:#888;font-weight:400; }

@media(max-width:900px){
  .testimonials-section { padding:80px 24px; }
  .testimonials-grid { grid-template-columns:1fr; }
}
</style>
