---
// src/pages/merci.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Merci — Misrah Print" description="Votre demande a bien été reçue. Nous vous répondons très rapidement.">

  <section class="merci-section">
    <div class="merci-inner">
      <div class="merci-icon">✓</div>
      <div class="section-tag">Message reçu</div>
      <h1 class="merci-title">Merci pour<br><em>votre demande !</em></h1>
      <p class="merci-desc">
        Nous avons bien reçu votre message et nous vous répondrons dans les
        plus brefs délais — généralement sous 24h.
      </p>
      <div class="merci-actions">
        <a href="/" class="btn-primary">Retour à l'accueil</a>
        <a href="/portfolio" class="btn-secondary">Voir nos réalisations</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.merci-section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 60px;
  background: var(--dark);
}
.merci-inner {
  max-width: 560px;
  text-align: center;
}
.merci-icon {
  width: 72px; height: 72px;
  border: 2px solid var(--red);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; color: var(--red);
  margin: 0 auto 32px;
}
.merci-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(48px, 6vw, 72px);
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -1px;
  line-height: 0.95;
  margin-bottom: 24px;
}
.merci-title em { font-style: italic; color: var(--red); }
.merci-desc {
  font-size: 16px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.8;
  margin-bottom: 48px;
}
.merci-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

@media(max-width: 600px) {
  .merci-section { padding: 100px 24px; }
}
</style>
